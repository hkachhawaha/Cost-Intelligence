# ── App ───────────────────────────────────────────────────────────────
ENVIRONMENT=local                # local | dev | staging | prod
LOG_LEVEL=INFO

# ── Datastores ────────────────────────────────────────────────────────
# Async driver for the app; Alembic derives the sync driver from this.
DATABASE_URL=postgresql+asyncpg://terzo:dev@localhost:5432/terzo
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
REDIS_URL=redis://localhost:6379/0
CLICKHOUSE_URL=http://localhost:8123

# ── Auth0 (SSO/SAML/SCIM) ─────────────────────────────────────────────
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://api.terzo.ai
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
# AUTH0_ISSUER=https://your-tenant.us.auth0.com/   # optional; derived from domain

# ── Object store / secrets ────────────────────────────────────────────
S3_BUCKET=terzo-cost-intelligence
AWS_REGION=us-east-1
SECRETS_PROVIDER=env             # env | aws_sm | gcp_sm

# ── LLM (Google Gemini; used from Phase 6, declared early) ────────────
# One key for generation (model gateway) + embeddings (Gemini Developer API).
GEMINI_API_KEY=

# ── Observability ─────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=     # e.g. http://localhost:4317 (blank disables)
OTEL_SERVICE_NAME=terzo-api

# ── Frontend (apps/web) ───────────────────────────────────────────────
NEXT_PUBLIC_API_BASE=http://localhost:8000/api/v1
AUTH0_SECRET=run-`openssl rand -hex 32`
AUTH0_BASE_URL=http://localhost:3000
AUTH0_ISSUER_BASE_URL=https://your-tenant.us.auth0.com
