{
  "name": "cost-intelligence",
  "version": "0.1.0",
  "private": true,
  "description": "Terzo Cost Intelligence — AI-agent-driven platform mapping spend to contracts",
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "build:web": "pnpm --filter web build",
    "lint:web": "pnpm --filter web lint",
    "typecheck:web": "pnpm --filter web typecheck",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down"
  },
  "dependencies": {
    "next": "14.2.15"
  },
  "packageManager": "pnpm@9.7.0",
  "engines": {
    "node": ">=20"
  }
}
